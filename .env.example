# Copy this file to .env for local SMTP testing or to /etc/pawnest.env on VPS.
# Do not commit real .env files because they contain secrets.

SECRET_KEY=change-me-to-a-long-random-production-secret
DEBUG=false
ALLOWED_HOSTS=example.com,www.example.com,127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=https://renjiale549-hash.github.io
CORS_ALLOW_CREDENTIALS=false

# Local development can omit DATABASE_URL and keep SQLite.
# Production PostgreSQL example:
DATABASE_URL=postgres://pawnest_user:change-me@127.0.0.1:5432/pawnest

STATIC_ROOT=/var/www/pawnest/staticfiles
MEDIA_ROOT=/var/www/pawnest/media
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false

DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_DELIVERY_PROVIDER=django
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=your-sender@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=PawNest <your-sender@gmail.com>
CONTRACT_NOTIFICATION_EMAIL=renjiale549@gmail.com
ORDER_NOTIFICATION_EMAIL=renjiale549@gmail.com
SEND_CUSTOMER_ORDER_EMAIL=true

# Render free web services block SMTP ports. Use Resend over HTTPS instead:
# EMAIL_DELIVERY_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=PawNest <onboarding@resend.dev>
